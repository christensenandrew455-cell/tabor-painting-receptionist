# Server
PORT=3000
PUBLIC_URL=https://tabor-painting-receptionist-production.up.railway.app

# Required provider secrets
TELNYX_API_KEY=your_telnyx_api_key
OPENAI_API_KEY=your_openai_api_key

# ARK OCM connection
# Use the production OCM deployment. Never use a Vercel preview deployment here.
OCM_WEBHOOK_URL=https://ark-websites-ocm.vercel.app/api/intake
OCM_CONNECTION_KEY=replace_with_the_business_connection_key
OCM_CLIENT_ID=tabor-painting
OCM_SOURCE=tabor-painting-receptionist

# One portable business-information variable.
# It may be a JSON object like this, or plain text containing extra information.
BUSINESS_INFO={"name":"Tabor Painting","receptionist":"Alex","owner":"Jason Beirne","phone":"(774) 245-3383","email":"Taborpainting508@gmail.com","hours":"Monday through Friday, 8 AM to 5 PM","estimateDays":"Monday through Friday","estimateWeekdays":["monday","tuesday","wednesday","thursday","friday"],"earliestEstimateStart":"9:00 AM","latestEstimateStart":"4:30 PM","base":"Berlin, Massachusetts","serviceAreas":["Berlin","Bolton","Hudson","Clinton","Marlborough","Northborough","Boylston","West Boylston","Sterling","Lancaster","Worcester"],"services":{"interior painting":"Walls, rooms, ceilings, trim, doors, touch-ups, repainting, and other indoor painting.","exterior painting":"Exterior surfaces and trim, with careful surface preparation and clean coverage.","small paint repair":"Small touch-ups, minor paint damage, and small paint or patch repairs.","wood staining":"Staining wood surfaces such as decks, fences, trim, and other wood features."},"about":["Tabor Painting is a residential painting company based in Berlin, Massachusetts.","The company focuses on careful preparation, clean work areas, clear communication, attention to detail, smooth finishes, and professional long-lasting results."]}

