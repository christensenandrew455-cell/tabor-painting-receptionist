# Exact Railway variable contract for one receptionist clone.
# Railway supplies PORT automatically. Do not add PORT yourself.

PUBLIC_URL=https://your-receptionist.example.com
TELNYX_API_KEY=EXAMPLE_NOT_A_REAL_TELNYX_KEY
OPENAI_API_KEY=EXAMPLE_NOT_A_REAL_OPENAI_KEY
OCM_CLIENT_ID=example-business
OCM_CONNECTION_KEY=EXAMPLE_NOT_A_REAL_CONNECTION_KEY

# One JSON variable containing every business-specific fact.
BUSINESS_INFO={"name":"Example Business","receptionist":"Alex","owner":"Example Owner","phone":"(555) 555-0100","email":"hello@example.com","hours":"Monday through Friday, 8 AM to 5 PM","timeZone":"America/New_York","estimateDays":"Monday through Friday","estimateWeekdays":["monday","tuesday","wednesday","thursday","friday"],"earliestEstimateStart":"9:00 AM","latestEstimateStart":"4:30 PM","base":"Example City","serviceAreas":["Example City"],"services":{"example service":"Description of the service."},"about":["Short business description."],"openingLine":"Hi, this is {{receptionist_name}} with {{business_name}}. Can I set you up with an estimate today?","closingLine":"{{owner_first_name}} will follow up with you shortly. Thanks for calling {{business_name}}. Goodbye.","extraInformation":""}

# Optional. Leave empty to keep the tested default intake script.
RECEPTIONIST_SCRIPT=

# Optional AI behavior overrides.
AI_MODEL=gpt-realtime-mini
AI_VOICE=alloy
AI_SPEECH_SPEED=0.94
AI_SILENCE_MS=1200
